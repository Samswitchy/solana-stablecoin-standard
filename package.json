{
  "name": "solana-stablecoin-standard",
  "version": "0.2.0",
  "description": "Open-source SDK and standards scaffold for stablecoins on Solana",
  "type": "module",
  "bin": {
    "sss-token": "./bin/sss-token.js"
  },
  "scripts": {
    "test": "node --test",
    "test:rust": "cargo test --offline",
    "test:integration": "SSS_RUN_LOCALNET_TESTS=1 node --test test/onchain.integration.test.js",
    "build:anchor": "anchor build",
    "lint": "node --check src/*.js test/*.js services/*.js bin/*.js",
    "service:mint-burn": "node services/mint-burn.js",
    "service:compliance": "node services/compliance.js",
    "service:indexer": "node services/indexer.js",
    "service:webhook": "node services/webhook.js"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.13",
    "@solana/spl-token-metadata": "^0.1.6",
    "@solana/web3.js": "^1.98.0"
  },
  "keywords": [
    "solana",
    "stablecoin",
    "token-2022",
    "sdk",
    "cli"
  ],
  "license": "MIT"
}
